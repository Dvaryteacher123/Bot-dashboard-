{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "env": {
    "HARAKAPAY_API_KEY": "hpk_your_actual_api_key_here",
    "HARAKAPAY_BASE_URL": "https://harakapay.net",
    "HARAKAPAY_MERCHANT_ID": "your_merchant_id_here",
    "APP_NAME": "Free Odd & Mikeka",
    "APP_URL": "https://freeodd-mikeka.vercel.app",
    "WEBHOOK_URL": "https://freeodd-mikeka.vercel.app/webhook/haraka-pay"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
